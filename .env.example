# Copy this file to .env and fill in your keys
# The app also accepts keys directly in the sidebar UI

# Required — get yours at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Job Search APIs ───────────────────────────────────────────────────────────
# The Muse, Arbeitnow, and RemoteOK work WITHOUT any API keys.
# Add keys below to unlock LinkedIn, Indeed, Glassdoor, and more.

# ⭐ BEST: SerpAPI — Google Jobs (LinkedIn, Indeed, Glassdoor, ZipRecruiter)
# 100 free searches/month at serpapi.com
SERPAPI_KEY=your_serpapi_key_here

# JSearch via RapidAPI — aggregates LinkedIn, Indeed, and more
# Free tier at: rapidapi.com (search "JSearch" to subscribe)
RAPIDAPI_KEY=your_rapidapi_key_here

# Adzuna — global job board
# Free registration at: developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key
